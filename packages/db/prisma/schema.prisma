// Red Zone Fantasy — Prisma Schema
// Docs: https://pris.ly/d/prisma-schema
// Run `pnpm db:migrate` to apply changes locally
// Run `pnpm db:generate` to regenerate the Prisma client

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector, pg_trgm, unaccent]
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserTier {
  free
  paid
}

enum UserRole {
  user
  admin
}

enum AgentRunStatus {
  queued
  running
  done
  failed
}

enum AgentResultRating {
  up
  down
}

enum LeagueStyle {
  redraft
  keeper
  dynasty
}

enum ScoringPriority {
  ppr
  half_ppr
  standard
}

enum PlayStyle {
  safe_floor
  balanced
  boom_bust
}

enum ReportFormat {
  detailed
  concise
}

enum TrendingType {
  add
  drop
}

/// The platform a ContentSource originates from.
enum ContentPlatform {
  rss
  youtube
  twitter
  podcast
  reddit
  api
  manual
}

/// The type of a single ContentItem.
enum ContentType {
  article
  video
  social_post
  podcast_episode
  vlog
  stat_update
}

/// How a player alias was generated.
enum AliasType {
  full_name
  last_name
  first_last_initial
  nickname
  social_handle
  abbreviation
  custom
}

// ─── Core User Models ────────────────────────────────────────────────────────

/// Application user. Auth source of truth is Clerk — synced via webhook.
model User {
  id String @id @default(cuid())

  /// Clerk user ID — links our DB record to Clerk's auth record
  clerkId String @unique

  email String @unique
  tier  UserTier @default(free)
  role  UserRole @default(user)

  /// Remaining agent run credits. Free = 2 (lifetime). Paid = 50/mo.
  runCredits Int @default(2)

  /// Stripe fields — populated on first checkout (Phase 2)
  stripeCustomerId         String?
  stripeSubscriptionId     String?
  stripeSubscriptionStatus String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sleeperProfile  SleeperProfile?
  yahooProfile    YahooProfile?
  espnProfile     ESPNProfile?
  preferences     UserPreferences?
  agentRuns       AgentRun[]
  tokenBudget     TokenBudget[]
  analyticsEvents AnalyticsEvent[]
  customFeeds     CustomFeed[]
  chatSessions    ChatSession[]

  @@map("users")
}

/// Linked Sleeper account for a user.
model SleeperProfile {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Sleeper's internal user_id
  sleeperId   String
  displayName String

  /// Snapshot of the user's leagues array from Sleeper API
  leagues Json @default("[]")

  updatedAt DateTime @updatedAt

  @@map("sleeper_profiles")
}

/// Per-user agent customization preferences.
/// These are injected into every agent run as system context.
model UserPreferences {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  leagueStyle      LeagueStyle     @default(redraft)
  scoringPriority  ScoringPriority @default(ppr)
  playStyle        PlayStyle       @default(balanced)
  reportFormat     ReportFormat    @default(detailed)

  /// Array of positions the user cares most about e.g. ["RB", "WR"]
  priorityPositions String[]

  /// Free-text prompt additions injected into every agent run
  customInstructions String?

  notifyOnInjury   Boolean @default(false)
  notifyOnTrending Boolean @default(false)

  updatedAt DateTime @updatedAt

  @@map("user_preferences")
}

// ─── Agent Execution ─────────────────────────────────────────────────────────

/// Record of every agent job execution.
model AgentRun {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// e.g. "team_eval", "waiver", "lineup"
  agentType String

  status AgentRunStatus @default(queued)

  /// Typed agent input (stored as JSON)
  inputJson Json

  /// Typed agent output (null until status = done)
  outputJson Json?

  tokensUsed   Int?
  durationMs   Int?

  /// User feedback on result quality
  rating AgentResultRating?

  errorMessage String?

  /// Confidence score 0-100 based on source quality, coverage, and recency
  confidenceScore Int?
  /// JSON breakdown of sources and content items injected for this run
  sourcesUsed     Json?

  /// Groups runs made within the same user session for cross-agent context injection
  sessionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([agentType])
  @@index([status])
  @@index([createdAt])
  @@index([sessionId])
  @@map("agent_runs")
}

/// Monthly token + run usage tracking per user.
model TokenBudget {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  periodStart DateTime
  tokensUsed  Int      @default(0)
  runsUsed    Int      @default(0)

  @@unique([userId, periodStart])
  @@map("token_budgets")
}

// ─── Analytics ───────────────────────────────────────────────────────────────

/// Flexible event store for behavioral analytics and system telemetry.
/// Use track() helper — never insert directly.
/// See docs/DATA.md for full event type catalog.
model AnalyticsEvent {
  id String @id @default(cuid())

  /// Nullable — some events are system-level (ingestion jobs, etc.)
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  /// Typed event name e.g. "user.signup", "agent.run.completed"
  eventType String

  /// Event-specific payload. Schema varies by eventType — see docs/DATA.md
  payload Json

  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([userId])
  @@index([createdAt])
  @@map("analytics_events")
}

// ─── NFL Player Data (cached from Sleeper) ───────────────────────────────────

/// All NFL players, refreshed daily from Sleeper /players/nfl.
/// Primary key is Sleeper's player_id string.
model Player {
  sleeperId String @id

  firstName String
  lastName  String
  position  String
  team      String?

  /// Active, Injured Reserve, PUP, etc.
  status String

  /// Questionable, Doubtful, Out, IR — null if healthy
  injuryStatus String?

  /// Full, Limited, Did Not Practice — null if no report
  practiceParticipation String?

  /// e.g. "QB1", "RB2"
  depthChartPosition String?

  /// 1 = starter, 2 = backup — lower is better
  depthChartOrder Int?

  /// Sleeper's built-in rough ranking across all players
  searchRank Int?

  age      Int?
  yearsExp Int?

  /// FantasyPros numeric probability of playing this week (0.0–1.0). Updated by fp_injuries_refresh.
  probabilityOfPlaying Float?

  /// Full raw Sleeper player object — preserved for future use
  metadata Json @default("{}")

  lastRefreshedAt DateTime @default(now())

  // Relations
  rankings        PlayerRanking[]
  projections     PlayerProjection[]
  trending        TrendingPlayer[]
  aliases         PlayerAlias[]
  contentMentions ContentPlayerMention[]
  tradeValues     PlayerTradeValue[]
  tradeVolume     PlayerTradeVolume?
  seasonStats     PlayerSeasonStats[]
  externalIds     PlayerExternalId[]
  propLines       PlayerPropLine[]

  @@index([position])
  @@index([team])
  @@index([injuryStatus])
  @@index([lastName])
  @@map("players")
}

/// Cross-source player ID mappings. Bridges our Sleeper-keyed Player records
/// to any number of third-party ID systems without polluting the Player table.
/// Add a row per source; never add source-specific columns to Player.
/// Known sources: "sportradar" | "fantasypros" | "espn" | "yahoo" | "cbs" | "mfl"
model PlayerExternalId {
  id        String @id @default(cuid())

  sleeperId String
  player    Player @relation(fields: [sleeperId], references: [sleeperId], onDelete: Cascade)

  /// Source identifier — e.g. "fantasypros", "sportradar", "espn", "yahoo", "cbs"
  source String

  /// The player's ID in that source's system (always stored as String)
  externalId String

  /// When this mapping was last confirmed valid by a sync job
  lastVerifiedAt DateTime @default(now())

  @@unique([sleeperId, source])
  @@unique([source, externalId])
  @@index([source])
  @@map("player_external_ids")
}

/// All known name variants for a player used during content entity resolution.
/// Auto-generated on player ingest; can be extended with custom entries.
model PlayerAlias {
  id String @id @default(cuid())

  playerId String
  player   Player @relation(fields: [playerId], references: [sleeperId], onDelete: Cascade)

  /// The alias string — e.g. "Mahomes", "Patrick Mahomes", "pmahomes15"
  alias String

  aliasType AliasType @default(full_name)

  @@unique([alias, aliasType])
  @@index([alias])
  @@map("player_aliases")
}

/// Consensus rankings from FantasyPros and other sources.
/// Updated weekly (Tuesday after MNF).
model PlayerRanking {
  id String @id @default(cuid())

  playerId String
  player   Player @relation(fields: [playerId], references: [sleeperId], onDelete: Cascade)

  /// "fantasypros" | "sleeper_trending" | "espn"
  source String

  rankOverall  Int
  rankPosition Int

  /// FP-native fields — populated by fp_rankings_refresh job
  /// FantasyPros tier grouping (1 = elite, 2 = solid, 3 = streamable, etc.)
  tier         Int?
  /// Formatted positional rank string e.g. "RB12"
  posRank      String?
  /// Per-format ECR ranks (overall rank varies by scoring)
  rankPpr      Int?
  rankHalfPpr  Int?
  rankStd      Int?
  /// Min and max rank across all experts — measures consensus tightness
  rankMin      Int?
  rankMax      Int?
  /// Standard deviation of expert ranks — high value = polarizing player
  rankStdDev   Float?
  /// Percentage of leagues the player is owned in (0–100)
  ownershipPct Float?

  week   Int
  season Int

  fetchedAt DateTime @default(now())

  @@unique([playerId, source, week, season])
  @@index([source, week, season])
  @@map("player_rankings")
}

/// Weekly fantasy point projections per player per source.
model PlayerProjection {
  id String @id @default(cuid())

  playerId String
  player   Player @relation(fields: [playerId], references: [sleeperId], onDelete: Cascade)

  /// "fantasypros" | "espn" | "numberfire"
  source  String
  week    Int
  season  Int

  /// Whether this is a rest-of-season projection (true) or single-week (false)
  isRos   Boolean @default(false)

  passYds    Float?
  passTd     Float?
  rushYds    Float?
  rushTd     Float?
  recYds     Float?
  recTd      Float?
  receptions Float?

  /// Projected fantasy points — STD scoring (base field)
  fpts     Float
  /// Projected fantasy points — PPR scoring
  fptsPpr  Float?
  /// Projected fantasy points — Half PPR scoring
  fptsHalf Float?

  fetchedAt DateTime @default(now())

  @@unique([playerId, source, week, season, isRos])
  @@index([source, week, season])
  @@map("player_projections")
}

/// Waiver wire trending data from Sleeper. Updated hourly.
model TrendingPlayer {
  id String @id @default(cuid())

  playerId String
  player   Player @relation(fields: [playerId], references: [sleeperId], onDelete: Cascade)

  type         TrendingType
  count        Int
  lookbackHours Int @default(24)

  fetchedAt DateTime @default(now())

  @@index([type, fetchedAt])
  @@map("trending_players")
}

/// NFL team defensive rankings vs each position.
/// Used to assess matchup quality (e.g. "KC allows fewest points to WRs").
model NFLTeamDefense {
  id String @id @default(cuid())

  /// NFL team abbreviation e.g. "KC", "BUF"
  team   String
  season Int
  week   Int

  /// Average fantasy points allowed to each position
  ptsAllowedQB Float?
  ptsAllowedRB Float?
  ptsAllowedWR Float?
  ptsAllowedTE Float?

  /// Rank 1-32 vs each position (1 = toughest matchup, 32 = easiest)
  rankVsQB Int?
  rankVsRB Int?
  rankVsWR Int?
  rankVsTE Int?

  fetchedAt DateTime @default(now())

  @@unique([team, week, season])
  @@index([week, season])
  @@map("nfl_team_defense")
}

// ─── Content Sources ─────────────────────────────────────────────────────────

/// Registry of all content ingestion sources.
/// Each source maps to a platform type and feed URL.
model ContentSource {
  id   String @id @default(cuid())

  /// Human-readable name e.g. "The Fantasy Footballers", "Adam Schefter"
  name String

  platform ContentPlatform

  /// RSS URL, YouTube channel URL, X user URL, podcast feed, etc.
  feedUrl String

  /// URL to source logo/avatar for directory UI
  avatarUrl String?

  /// Platform-specific config: YouTube channel ID, X user ID, RSS selectors, etc.
  platformConfig Json @default("{}")

  /// How often to re-fetch in minutes
  refreshIntervalMins Int      @default(60)
  lastFetchedAt       DateTime?
  isActive            Boolean  @default(true)

  /// Agent injection tier: 1=premium (beat reporters), 2=established, 3=general
  tier Int @default(2)

  /// Partner/sponsor highlight — shown with a badge in the directory
  featured    Boolean  @default(false)
  /// Tiered partner display: "gold", "silver", "bronze", or null
  partnerTier String?

  items ContentItem[]

  @@unique([platform, feedUrl])
  @@map("content_sources")
}

/// Normalized content from all ingested sources.
/// All platforms (RSS, YouTube, Twitter, podcast) map to this unified shape.
model ContentItem {
  id String @id @default(cuid())

  sourceId String?
  source   ContentSource? @relation(fields: [sourceId], references: [id])

  contentType ContentType

  /// Canonical URL — used for deduplication
  sourceUrl String @unique

  title     String
  /// AI-generated or extracted summary (~2-3 sentences)
  summary   String? @db.Text

  /// Full text content or video transcript — stored for search and future embedding
  rawContent String @db.Text

  /// For video/social: thumbnail or preview image URL
  thumbnailUrl String?

  authorName  String?
  publishedAt DateTime?

  /// Platform-specific metadata:
  /// - video: { duration, viewCount, likeCount, channelId }
  /// - podcast: { duration, episodeNumber, showName }
  /// - tweet: { likeCount, retweetCount, replyCount, tweetId }
  mediaMeta Json @default("{}")

  /// Content topic tags e.g. ["injury", "trade", "waiver", "matchup", "breakout", "depth_chart"]
  topics String[]

  /// 0-1 importance score (set during ingestion or by a scoring job)
  importanceScore Float?
  /// 0-1 novelty vs. already-known info
  noveltyScore    Float?
  /// -1 to 1 overall sentiment
  sentimentScore  Float?

  /// Postgres full-text search vector. Auto-updated via DB trigger.
  /// Weights: title=A, summary=B, rawContent=C, authorName=D
  searchVector Unsupported("tsvector")?

  /// pgvector embedding (1536-dim, text-embedding-3-small).
  /// NULL until embedding generation is activated post-MVP.
  embedding Unsupported("vector(1536)")?

  /// For chunked content: references the parent item this chunk belongs to
  parentId String?
  parent   ContentItem?  @relation("ContentChunks", fields: [parentId], references: [id])
  chunks   ContentItem[] @relation("ContentChunks")

  fetchedAt DateTime @default(now())

  // Relations
  playerMentions ContentPlayerMention[]

  @@index([contentType])
  @@index([fetchedAt])
  @@index([publishedAt])
  @@index([parentId])
  @@map("content_items")
}

/// Trade transactions ingested from Sleeper league transactions API.
/// Populated via TRADE_REFRESH ingestion job — one record per unique trade.
model TradeTransaction {
  id            String @id @default(cuid())
  leagueId      String
  transactionId String @unique

  /// NFL week the trade occurred
  week   Int
  season String

  /// Map of { playerId: rosterId } — players/picks received per team
  adds Json
  /// Map of { playerId: rosterId } — players/picks given up per team
  drops Json

  /// Draft picks traded: [{ season, round, roster_id, previous_owner_id, owner_id }]
  draftPicks Json @default("[]")

  /// FAAB dollars transferred: [{ sender, receiver, amount }]
  waiverBudget Json @default("[]")

  /// Roster IDs of teams involved
  rosterIds Int[]

  /// Unix ms timestamp from Sleeper
  createdAt DateTime

  fetchedAt DateTime @default(now())

  /// Dynasty, redraft, or keeper — from Sleeper league settings (type 0=redraft,1=keeper,2=dynasty)
  leagueType    LeagueStyle?
  /// Number of teams in the league
  teamCount     Int?
  /// Whether the league uses a SUPER_FLEX roster spot
  isSuperflex   Boolean?
  /// Scoring format derived from Sleeper settings.rec (0=standard, 0.5=half_ppr, 1=ppr)
  scoringFormat ScoringPriority?

  @@index([leagueId, week, season])
  @@index([createdAt])
  @@index([leagueType])
  @@map("trade_transactions")
}

/// Dynasty and redraft trade values sourced from FantasyCalc (free public API).
/// Updated weekly on Tuesdays alongside rankings.
model PlayerTradeValue {
  id String @id @default(cuid())

  sleeperId String
  player    Player @relation(fields: [sleeperId], references: [sleeperId], onDelete: Cascade)

  /// "fantasycalc" — extensible to other sources
  source String @default("fantasycalc")

  /// Dynasty 1QB value (0-9999 scale, FantasyCalc scoring)
  dynasty1qb Int?
  /// Dynasty Superflex / 2QB value
  dynastySf Int?
  /// Redraft value (0-9999 scale)
  redraft Int?
  /// 30-day value change (positive = rising, negative = falling)
  trend30d Int?

  fetchedAt DateTime @default(now())

  @@unique([sleeperId, source])
  @@index([dynasty1qb])
  @@index([redraft])
  @@map("player_trade_values")
}

/// Community trade frequency sourced from Dynasty Daddy /trade/volume endpoint.
/// Updated weekly alongside other Dynasty Daddy data. One row per player.
model PlayerTradeVolume {
  sleeperId String @id
  player    Player @relation(fields: [sleeperId], references: [sleeperId], onDelete: Cascade)

  /// Number of community trades in the last 7 days
  count1w Int?
  /// Number of community trades in the last 14 days
  count2w Int?
  /// Number of community trades in the last 28 days
  count4w Int?
  /// Number of community trades in the last 56 days (8 weeks)
  count8w Int?

  /// Trade volume rank among all players, last 7 days
  rank1w Int?
  /// Trade volume rank among all players, last 28 days
  rank4w Int?
  /// Trade volume rank among all players, last 56 days
  rank8w Int?

  fetchedAt DateTime @default(now())

  @@map("player_trade_volume")
}

/// Historical season statistics for NFL players, sourced from Sleeper's stats endpoint.
/// One row per player per season per season type (regular, pre, post).
/// Used by the follow-up chat to answer historical performance questions accurately.
model PlayerSeasonStats {
  id         String @id @default(cuid())

  playerId   String
  player     Player @relation(fields: [playerId], references: [sleeperId], onDelete: Cascade)

  /// NFL season year (e.g. 2023)
  season     Int
  /// "regular", "pre", or "post"
  seasonType String @default("regular")

  /// Core passing stats
  passYds    Float?
  passTds    Int?
  passInt    Int?
  passCmp    Float?
  passAtt    Int?

  /// Core rushing stats
  rushYds    Float?
  rushTds    Int?
  rushAtt    Int?

  /// Core receiving stats
  recYds     Float?
  recTds     Int?
  rec        Float?
  targets    Int?

  /// Fantasy scoring
  fantasyPtsPpr  Float?
  fantasyPtsStd  Float?

  /// Games played
  gamesPlayed Int?

  fetchedAt  DateTime @default(now())

  @@unique([playerId, season, seasonType])
  @@index([playerId])
  @@index([season])
  @@map("player_season_stats")
}

/// NFL player prop betting lines from The Odds API.
/// Updated Wed + Sat when lines firm. Used by Lineup, Waiver, Player Scout agents.
model PlayerPropLine {
  id        String @id @default(cuid())

  sleeperId String
  player    Player @relation(fields: [sleeperId], references: [sleeperId], onDelete: Cascade)

  /// Market key e.g. "player_rush_yds", "player_rec_yds", "player_pass_yds", "player_anytime_td"
  market    String
  /// Sportsbook key e.g. "draftkings", "fanduel", "betmgm"
  bookmaker String

  /// Over/under line (yards, etc.) — null for TD scorer markets
  line      Float?
  /// American odds for the over (e.g. -110) or anytime TD scorer
  overOdds  Int?
  /// American odds for the under (e.g. -110)
  underOdds Int?

  fetchedAt DateTime @default(now())

  @@unique([sleeperId, market, bookmaker])
  @@index([sleeperId])
  @@index([market])
  @@map("player_prop_lines")
}

/// Linked Yahoo Fantasy account for a user.
/// OAuth tokens refreshed automatically. Stores the active season's league IDs.
model YahooProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  yahooUserId  String
  displayName  String
  /// Serialized OAuth2 token (access_token, refresh_token, expiry)
  tokenJson    Json   @default("{}")
  /// Snapshot of the user's Yahoo league IDs for the active season
  leagues      Json   @default("[]")

  updatedAt DateTime @updatedAt

  @@map("yahoo_profiles")
}

/// Linked ESPN Fantasy account for a user.
/// Uses cookie-based auth (espn_s2 + SWID). No OAuth — user provides cookies.
model ESPNProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  espnUserId   String
  displayName  String
  /// Encrypted espn_s2 cookie value
  espnS2       String @db.Text
  /// ESPN SWID cookie value (public UUID)
  swid         String
  /// Snapshot of the user's ESPN league IDs for the active season
  leagues      Json   @default("[]")

  updatedAt DateTime @updatedAt

  @@map("espn_profiles")
}

/// Per-agent runtime configuration. System prompt and model tier are editable
/// in the admin dashboard without a code deploy. Seeded with defaults from
/// each agent's prompt.ts on first migration.
model AgentConfig {
  id           String   @id @default(cuid())
  agentType    String   @unique
  label        String
  description  String
  systemPrompt String   @db.Text
  modelTier    String   @default("haiku")
  maxTokens    Int?
  enabled      Boolean  @default(true)
  showInAnalyze Boolean @default(true)
  sortOrder    Int      @default(0)

  /// Source tiers allowed for injection (1=premium, 2=established, 3=general)
  allowedSourceTiers Int[]    @default([1, 2, 3])
  /// Platforms allowed for injection (rss, youtube, twitter, etc.)
  allowedPlatforms   String[] @default(["rss", "youtube"])
  /// Recency window in hours for content injection
  recencyWindowHours Int      @default(168)
  /// Max total content items to inject per run
  maxContentItems    Int      @default(10)

  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("agent_configs")
}

/// Join table: which players are mentioned in which content, with context.
/// Populated during ingestion via player entity resolution.
model ContentPlayerMention {
  id String @id @default(cuid())

  contentId String
  content   ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)

  playerId String
  player   Player @relation(fields: [playerId], references: [sleeperId], onDelete: Cascade)

  /// Type of mention: "injury_update" | "trade_rumor" | "start_recommendation" |
  /// "breakout_candidate" | "depth_chart_change" | "general"
  context String @default("general")

  /// -1 to 1 sentiment about this player in this specific content item
  sentiment Float?

  /// Short excerpt from the content mentioning the player (~1-2 sentences)
  snippet String? @db.Text

  @@unique([contentId, playerId])
  @@index([playerId, contentId])
  @@map("content_player_mentions")
}

model Feedback {
  id        String   @id @default(cuid())
  app       String
  message   String   @db.Text
  userId    String?
  userEmail String?
  userTier  String?
  pageUrl   String?
  createdAt DateTime @default(now())

  @@index([app])
  @@index([createdAt])
  @@map("feedback")
}

// ─── Directory — Rankings & Tools ────────────────────────────────────────────

/// External fantasy football ranking sites, managed via Admin Command Center.
model RankingSite {
  id              String   @id @default(cuid())
  name            String
  description     String
  url             String
  /// Manual logo URL — falls back to Clearbit auto-logo in the UI
  logoUrl         String?
  /// e.g. ["Redraft", "Dynasty", "DFS", "Best Ball", "Tools"]
  categories      String[]
  /// 1–10 community popularity score used for default sort order
  popularityScore Int      @default(5)
  promoCode       String?
  promoDesc       String?
  featured        Boolean  @default(false)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("ranking_sites")
}

/// Fantasy football product/tool directory, managed via Admin Command Center.
model FantasyTool {
  id          String   @id @default(cuid())
  name        String
  description String
  url         String
  /// Manual logo URL — falls back to Clearbit auto-logo in the UI
  logoUrl     String?
  /// e.g. ["AI", "Rankings", "DFS", "Trade Analysis", "Roster Mgmt", "Projections", "Dynasty", "News"]
  categories  String[]
  /// "free" | "paid" | "freemium"
  priceType   String
  /// Display price string e.g. "$7.99/mo" — null for free tools
  price       String?
  promoCode   String?
  promoDesc   String?
  featured    Boolean  @default(false)
  /// "gold" | "silver" | "bronze" — null for non-partners
  partnerTier String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("fantasy_tools")
}

/// User-saved custom content feeds (up to 5 for paid users).
model CustomFeed {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  /// Feed config: { feedType: "sleeper"|"players"|"team", sleeperLeagueId?, playerIds?, teamAbbr?, sources?, contentTypes? }
  config    Json     @default("{}")
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("custom_feeds")
}

/// A RosterMind AI chat session — one per conversation thread.
model ChatSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Optional LLM-generated summary after the session
  summary String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]

  @@index([userId])
  @@map("chat_sessions")
}

/// A single message within a ChatSession — mirrors the frontend ChatMessage union.
model ChatMessage {
  id        String @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  /// "user" | "assistant"
  role String
  /// "user" | "text" | "result" | "error" | "context-prompt" | "intent-confirm"
  type String
  /// Serialized message content (text or JSON)
  content String @db.Text

  /// Denormalized agent run ID when type = "result"
  agentRunId String?

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@map("chat_messages")
}

// ─── X / Twitter Engine ───────────────────────────────────────────────────────

/// A connected X/Twitter account used by the X Engine.
model XAccount {
  id           String    @id @default(cuid())
  handle       String
  xUserId      String    @unique
  /// "rostermind" | "directory" | "custom"
  label        String    @default("directory")
  /// Encrypted OAuth 2.0 access token
  accessToken  String    @db.Text
  refreshToken String?   @db.Text
  tokenExpiry  DateTime?
  isActive     Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scheduledPosts   ScheduledPost[]
  monitorRules     TweetMonitorRule[]
  pendingReplies   PendingReply[]

  @@map("x_accounts")
}

/// A tweet queued for posting by the X Engine.
model ScheduledPost {
  id String @id @default(cuid())

  xAccountId String
  xAccount   XAccount @relation(fields: [xAccountId], references: [id], onDelete: Cascade)

  /// Tweet body text (max 280 chars enforced in app)
  content    String   @db.Text
  /// Optional media attachment URLs
  mediaUrls  String[]
  /// "start_sit" | "waiver" | "trade" | "trending" | "matchup" | "custom"
  postType   String   @default("custom")

  scheduledFor DateTime
  /// "pending" | "posted" | "failed" | "cancelled"
  status       String   @default("pending")
  /// X tweet ID returned after successful post
  tweetId      String?
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([xAccountId, status])
  @@index([scheduledFor])
  @@map("scheduled_posts")
}

/// A saved search query used by the Tweet Monitor to ingest fantasy tweets.
model TweetMonitorRule {
  id String @id @default(cuid())

  xAccountId String
  xAccount   XAccount @relation(fields: [xAccountId], references: [id], onDelete: Cascade)

  /// Twitter search query, e.g. "#fantasyfootball waiver wire"
  query     String
  isActive  Boolean   @default(true)
  lastRanAt DateTime?

  createdAt DateTime @default(now())

  @@index([xAccountId])
  @@map("tweet_monitor_rules")
}

/// An @mention captured by the X Engine, queued for an AI-generated reply.
model PendingReply {
  id String @id @default(cuid())

  xAccountId String
  xAccount   XAccount @relation(fields: [xAccountId], references: [id], onDelete: Cascade)

  /// Original tweet ID that mentioned us
  tweetId      String @unique
  /// Author handle who mentioned us
  authorHandle String
  /// Full text of the mention
  tweetText    String @db.Text
  /// AI-generated reply draft (null until generated)
  aiReply      String? @db.Text
  /// "pending" | "approved" | "sent" | "skipped"
  status       String  @default("pending")
  sentAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([xAccountId, status])
  @@map("pending_replies")
}

// ─── Reddit Engine ────────────────────────────────────────────────────────────

/// A Reddit account used by the Reddit Engine for read monitoring + manual posts.
/// Read-first: ingestion runs automatically. Posting requires manual approval.
model RedditAccount {
  id          String  @id @default(cuid())
  username    String
  label       String  @default("rzf")
  isActive    Boolean @default(true)

  /// Encrypted OAuth2 access token
  accessToken  String @db.Text
  refreshToken String? @db.Text
  tokenExpiry  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  monitorRules  RedditMonitorRule[]
  pendingPosts  RedditPendingPost[]

  @@map("reddit_accounts")
}

/// A subreddit/search rule monitored by the Reddit Engine for content ingestion.
model RedditMonitorRule {
  id            String        @id @default(cuid())
  accountId     String
  account       RedditAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  /// Subreddit name without r/ prefix, e.g. "fantasyfootball"
  subreddit     String
  /// Optional flair or search query filter
  filter        String?
  isActive      Boolean       @default(true)
  lastRunAt     DateTime?

  createdAt DateTime @default(now())

  @@index([accountId])
  @@map("reddit_monitor_rules")
}

/// A post queued for manual approval before the Reddit Engine submits it.
model RedditPendingPost {
  id        String        @id @default(cuid())
  accountId String
  account   RedditAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  subreddit String
  title     String
  body      String  @db.Text
  postType  String  @default("text")

  /// "pending" | "approved" | "posted" | "rejected"
  status    String   @default("pending")
  postedUrl String?
  errorMsg  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId, status])
  @@map("reddit_pending_posts")
}
