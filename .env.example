# =============================================================
# Red Zone Fantasy — Environment Variable Catalog
# Copy this file to .env and fill in your values for local dev.
# Production values go in the Render + Vercel dashboards.
# NEVER commit .env — only .env.example is committed.
# =============================================================
# All vars are validated at startup via packages/shared/src/env.ts
# Add new vars there FIRST, then update this file.
# =============================================================

# ── Database ─────────────────────────────────────────────────
# Render Postgres URL (prod) or local Docker Postgres (dev)
DATABASE_URL=postgresql://rzf:rzf_local@localhost:5432/rzf_dev

# ── Redis ────────────────────────────────────────────────────
# Render Key Value / Redis URL (internal redis://... or TLS rediss://...)
# Local dev can still use redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ── Auth (Clerk) ─────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Get from: Clerk Dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=
# Routing — these match the Next.js route structure
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ── LLM Providers ────────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=
# Optional — GPT-4o-mini fallback. Get from: https://platform.openai.com
OPENAI_API_KEY=

# ── Fantasy Data ─────────────────────────────────────────────
# Sleeper API is fully public — no key required
# FantasyPros public API key — required for rankings, projections, news, injuries
# Free tier: 1 req/sec, 100 req/day. Get from: api@fantasypros.com
# Docs: https://api.fantasypros.com/public/v2/docs/
FANTASYPROS_API_KEY=

# ── Notifications ────────────────────────────────────────────
# OpenClaw operator Telegram bot — your private bot only
# Get from: @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Phase 2+ — user-facing Discord notifications
DISCORD_BOT_TOKEN=

# ── Telegram Agent Daemon (tools/telegram-agent/) ────────────
# Your numeric Telegram user ID — message @userinfobot to get it
TELEGRAM_ALLOWED_USER_ID=
# Your RZF database user ID (find in admin dashboard → Users)
TELEGRAM_OWNER_USER_ID=
# Deployed Render API URL (used by the daemon when away from desk)
# e.g. https://your-api.onrender.com  — no trailing slash
TELEGRAM_API_BASE_URL=http://localhost:3001
# Optional: pre-fill so /eval and /waiver work without typing a league ID
TELEGRAM_DEFAULT_LEAGUE_ID=
# Your GitHub repo in "owner/repo" format (used by /prs command)
GITHUB_REPO=
# Render service IDs — find in Render Dashboard → Service → Settings → General
RENDER_SERVICE_ID_API=
RENDER_SERVICE_ID_WORKER=
# Workspace absolute path (defaults to two dirs up from tools/telegram-agent/src)
# Override if you start the daemon from a different working directory
WORKSPACE_PATH=

# ── Payments (Stripe) ────────────────────────────────────────
# Stubbed in Phase 1. Get from: https://dashboard.stripe.com
STRIPE_SECRET_KEY=
# Get from: Stripe Dashboard → Webhooks → your endpoint → Signing Secret
STRIPE_WEBHOOK_SECRET=
# Stripe price ID for the Pro subscription — create in Stripe Dashboard → Products
STRIPE_PRICE_ID=price_

# ── Directory App ────────────────────────────────────────────────────────────
# URL of the RosterMind app (used in the Directory "Try RosterMind AI" CTA)
NEXT_PUBLIC_ROSTERMIND_URL=https://your-rostermind-url.vercel.app
# Clerk app for the Directory (separate Clerk application from RosterMind)
DIRECTORY_CLERK_PUBLISHABLE_KEY=
DIRECTORY_CLERK_SECRET_KEY=
# Stripe for Directory Pro tier (separate price from RosterMind)
DIRECTORY_STRIPE_PRICE_ID=price_

# ── Browse-Mode Agents ───────────────────────────────────────
# Phase 5 — Orgo VM runner for web scraping tasks
ORGO_API_KEY=

# ── External Data Sources ─────────────────────────────────────
# YouTube Data API v3 key — required for YouTube channel ingestion
# Get one at: console.cloud.google.com → APIs & Services → YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# The Odds API — required for NFL player prop lines (yards O/U, TD odds)
# Free tier: 500 requests/month. Get from: https://the-odds-api.com
THE_ODDS_API_KEY=

# Reddit OAuth (for reddit-engine post submission — NOT required for read-only ingestion)
# Create app at: https://www.reddit.com/prefs/apps (script type)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── Infrastructure / DevOps ──────────────────────────────────
# Render API key — used by the Render MCP server in .cursor/mcp.json
# Gives Cursor access to service metrics, logs, and deployments.
# Get from: Render Dashboard → Account Settings → API Keys
RENDER_API_KEY=
ERASER_API_TOKEN=

# ── Internal / App Config ────────────────────────────────────
# Used to protect /internal routes when session-based auth is unavailable
ADMIN_SECRET=change_me_in_production
# Internal API base URL (used by worker and web to reach the API)
API_BASE_URL=http://localhost:3001
# BullMQ: max parallel jobs per worker instance
WORKER_CONCURRENCY=5
# Node environment
NODE_ENV=development
